{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "health-charted/reference-index",
  "title": "Health Charted Reference Index",
  "description": "Index of reference files with entity coverage for cross-referencing and gap detection.",
  "type": "object",
  "properties": {
    "_type": {
      "const": "health-charted/reference-index",
      "description": "File type identifier"
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "file": { "type": "string", "description": "Filename relative to reference/" },
          "topic": { "type": "string" },
          "summary": { "type": "string" },
          "when_to_reference": { "type": "string", "description": "When this file is useful during a session" },
          "entities": {
            "type": "object",
            "description": "Canonical entity names covered by this file, keyed by entity type.",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
